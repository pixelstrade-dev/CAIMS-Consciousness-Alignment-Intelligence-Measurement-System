# ─── LLM Provider ─────────────────────────────────────────────────
# Supported providers: anthropic (default), openai
CAIMS_LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (set CAIMS_LLM_PROVIDER=openai to use)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── DATABASE ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://caims:change-me-in-production@localhost:5432/caims

# ─── CAIMS CONFIG ─────────────────────────────────────────────────
CAIMS_SCORING_MODEL=claude-sonnet-4-20250514
CAIMS_ENABLE_DEBATES=true
CAIMS_MAX_HISTORY_TURNS=20
CAIMS_CFI_WARNING_THRESHOLD=40
CAIMS_CFI_CRITICAL_THRESHOLD=20
# CAIMS_WEIGHTS={"cq":0.35,"aq":0.25,"cfi":0.20,"eq":0.12,"sq":0.08}
